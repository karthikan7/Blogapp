<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title>Blogify — Latest Stories</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Poppins', sans-serif;
            background: #06080f;
            min-height: 100vh;
            overflow-x: hidden;
        }

        .bg-orb {
            position: fixed;
            border-radius: 50%;
            filter: blur(100px);
            opacity: 0.18;
            pointer-events: none;
            z-index: 0;
        }
        .orb1 { width: 600px; height: 600px; background: #5b4cdb; top: -200px; left: -180px; }
        .orb2 { width: 400px; height: 400px; background: #db4ca0; top: 300px; right: -120px; }
        .orb3 { width: 350px; height: 350px; background: #0ea5e9; bottom: 0; left: 38%; }

        .page-content {
            position: relative;
            z-index: 1;
            max-width: 1200px;
            margin: 0 auto;
            padding: 70px 24px 100px;
        }

        /* Header */
        .page-header {
            text-align: center;
            margin-bottom: 64px;
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            color: #7c6fee;
            margin-bottom: 18px;
            padding: 6px 16px;
            background: rgba(124,111,238,0.1);
            border: 1px solid rgba(124,111,238,0.2);
            border-radius: 999px;
        }

        .page-title {
            font-size: clamp(36px, 6vw, 64px);
            font-weight: 700;
            color: #f0eeff;
            line-height: 1.1;
            margin-bottom: 14px;
            letter-spacing: -0.02em;
        }

        .page-title span {
            background: linear-gradient(135deg, #a78bfa, #ec4899);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .page-subtitle {
            font-size: 14px;
            color: #4a5568;
            font-weight: 300;
            margin-bottom: 28px;
        }

        .btn-write {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 28px;
            background: linear-gradient(135deg, #5b4cdb, #8b5cf6);
            color: #fff;
            border-radius: 999px;
            font-family: 'Poppins', sans-serif;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            box-shadow: 0 8px 28px rgba(91,76,219,0.4);
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .btn-write:hover {
            transform: translateY(-3px);
            box-shadow: 0 14px 40px rgba(91,76,219,0.55);
            color: #fff;
            text-decoration: none;
        }

        /* Grid */
        .blog-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 22px;
        }

        /* Card */
        .blog-card {
            background: rgba(255,255,255,0.025);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 20px;
            overflow: hidden;
            text-decoration: none;
            color: inherit;
            display: flex;
            flex-direction: column;
            position: relative;
            transition: transform 0.4s cubic-bezier(0.23,1,0.32,1), box-shadow 0.4s, border-color 0.3s;
            animation: cardIn 0.7s both;
            backdrop-filter: blur(10px);
        }

        @keyframes cardIn {
            from { opacity: 0; transform: perspective(1000px) translateY(36px) rotateX(6deg); }
            to   { opacity: 1; transform: perspective(1000px) translateY(0) rotateX(0); }
        }

        .blog-card:nth-child(1) { animation-delay: 0.05s; }
        .blog-card:nth-child(2) { animation-delay: 0.12s; }
        .blog-card:nth-child(3) { animation-delay: 0.19s; }
        .blog-card:nth-child(4) { animation-delay: 0.26s; }
        .blog-card:nth-child(5) { animation-delay: 0.33s; }
        .blog-card:nth-child(6) { animation-delay: 0.40s; }

        .blog-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 50% 0%, rgba(124,111,238,0.1), transparent 60%);
            opacity: 0;
            transition: opacity 0.3s;
            pointer-events: none;
            z-index: 1;
        }

        .blog-card:hover {
            transform: perspective(1000px) rotateX(-3deg) rotateY(2deg) translateY(-8px) scale(1.015);
            border-color: rgba(124,111,238,0.45);
            box-shadow: 0 24px 56px rgba(91,76,219,0.28), 0 0 0 1px rgba(124,111,238,0.2);
            text-decoration: none;
            color: inherit;
        }

        .blog-card:hover::before { opacity: 1; }

        /* Cover */
        .card-cover {
            width: 100%;
            height: 200px;
            object-fit: cover;
            display: block;
        }

        .card-cover-placeholder {
            width: 100%;
            height: 200px;
            background: linear-gradient(135deg, #0d0b1e, #1a1438, #0d1624);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 40px;
            color: rgba(124,111,238,0.2);
        }

        /* Card body */
        .card-body {
            padding: 20px 22px 22px;
            flex: 1;
            display: flex;
            flex-direction: column;
            position: relative;
            z-index: 2;
        }

        .card-date {
            font-size: 10px;
            font-weight: 500;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #2d3748;
            margin-bottom: 8px;
        }

        .card-title {
            font-size: 16px;
            font-weight: 600;
            color: #eee8ff;
            line-height: 1.4;
            margin-bottom: 8px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .card-text {
            font-size: 12px;
            color: #3d4a5c;
            font-weight: 300;
            line-height: 1.7;
            flex: 1;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            margin-bottom: 16px;
        }

        /* Card footer */
        .card-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding-top: 12px;
            border-top: 1px solid rgba(255,255,255,0.04);
        }

        .card-author {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .author-avatar {
            width: 26px;
            height: 26px;
            border-radius: 50%;
            background: linear-gradient(135deg, #5b4cdb, #db4ca0);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 9px;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
        }

        .author-name {
            font-size: 11px;
            color: #4a5568;
            font-weight: 500;
        }

        .read-more {
            font-size: 11px;
            font-weight: 600;
            color: #7c6fee;
            display: flex;
            align-items: center;
            gap: 4px;
            transition: gap 0.2s;
        }

        .blog-card:hover .read-more { gap: 8px; }

        /* Empty state */
        .empty-state {
            grid-column: 1 / -1;
            text-align: center;
            padding: 80px 20px;
        }

        .empty-icon {
            font-size: 48px;
            color: rgba(124,111,238,0.18);
            margin-bottom: 16px;
        }

        .empty-state h3 {
            font-size: 22px;
            font-weight: 600;
            color: #eee8ff;
            margin-bottom: 8px;
        }

        .empty-state p {
            font-size: 14px;
            color: #3d4a5c;
            font-weight: 300;
            margin-bottom: 24px;
        }
    </style>
</head>
<body>

    <div class="bg-orb orb1"></div>
    <div class="bg-orb orb2"></div>
    <div class="bg-orb orb3"></div>

    <%- include('./partials/nav') %>

    <div class="page-content">

        <div class="page-header">
            <div><span class="eyebrow">✦ Latest Stories</span></div>
            <h1 class="page-title">Words that <span>inspire</span></h1>
            <p class="page-subtitle"><%= blog.length %> <%= blog.length === 1 ? 'story' : 'stories' %> published</p>
            <% if (user) { %>
                <a href="/blog/add" class="btn-write">
                    <i class="bi bi-pencil-fill"></i> Write a story
                </a>
            <% } %>
        </div>

        <div class="blog-grid">
            <% if (blog.length === 0) { %>
                <div class="empty-state">
                    <div class="empty-icon"><i class="bi bi-journal-text"></i></div>
                    <h3>No stories yet</h3>
                    <p>Be the first one to share your thoughts</p>
                    <% if (user) { %>
                        <a href="/blog/add" class="btn-write">
                            <i class="bi bi-pencil-fill"></i> Write first story
                        </a>
                    <% } %>
                </div>
            <% } else { %>
                <% blog.forEach(function(b) { %>
                    <a class="blog-card" href="/blog/<%= b._id %>">
                        <% if (b.coverImage) { %>
                            <img class="card-cover" src="<%= b.coverImage %>" alt="<%= b.title %>">
                        <% } else { %>
                            <div class="card-cover-placeholder">
                                <i class="bi bi-image"></i>
                            </div>
                        <% } %>
                        <div class="card-body">
                            <span class="card-date">
                                <%= new Date(b.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %>
                            </span>
                            <h2 class="card-title"><%= b.title %></h2>
                            <p class="card-text"><%= b.body %></p>
                            <div class="card-footer">
                                <div class="card-author">
                                    <div class="author-avatar">
                                        <%= b.createdBy ? b.createdBy.toString().slice(-2).toUpperCase() : 'AN' %>
                                    </div>
                                    <span class="author-name">Author</span>
                                </div>
                                <span class="read-more">
                                    Read <i class="bi bi-arrow-right"></i>
                                </span>
                            </div>
                        </div>
                    </a>
                <% }) %>
            <% } %>
        </div>
    </div>

    <%- include('./partials/script') %>

    <script>
        document.querySelectorAll('.blog-card').forEach(card => {
            card.addEventListener('mousemove', e => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                const cx = rect.width / 2;
                const cy = rect.height / 2;
                const rotY = ((x - cx) / cx) * 6;
                const rotX = -((y - cy) / cy) * 6;
                card.style.transform = `perspective(1000px) rotateX(${rotX}deg) rotateY(${rotY}deg) translateY(-8px) scale(1.015)`;
            });
            card.addEventListener('mouseleave', () => {
                card.style.transform = '';
            });
        });
    </script>

</body>
</html>